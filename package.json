{
  "name": "swiftly",
  "version": "1.0.0",
  "description": "AI-Powered Command Center for monday.com — Cross-board reporting, AI chat, time tracking, and Sidekick skills",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:client": "vite",
    "dev:server": "nodemon --watch src/server src/server/index.js",
    "build": "vite build",
    "preview": "vite preview",
    "start": "node src/server/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "lint": "eslint src/"
  },
  "dependencies": {
    "@react-pdf/renderer": "^4.1.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.0",
    "monday-sdk-js": "^0.5.8",
    "monday-ui-react-core": "^2.149.0",
    "node-fetch": "^3.3.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.0",
    "recharts": "^2.13.0"
  },
  "devDependencies": {
    "@mondaycom/apps-cli": "^4.10.5",
    "@playwright/test": "^1.49.0",
    "@types/react": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "concurrently": "^9.1.0",
    "eslint": "^9.14.0",
    "localtunnel": "^2.0.2",
    "nodemon": "^3.1.0",
    "vite": "^6.0.0",
    "vitest": "^2.1.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
